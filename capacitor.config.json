{
  "appId": "com.outstandingpartner.app",
  "appName": "Outstanding Partner",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "ios": {
    "contentInset": "always"
  },
  "plugins": {
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    },
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#000000",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    }
  }
}
